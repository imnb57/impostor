# ── Firebase web app credentials ────────────────────────────────────────────
# Firebase console → Project settings → Your apps → Web app → SDK setup.
# Copy this file to .env and fill in every value. All values must keep the
# EXPO_PUBLIC_ prefix (Expo inlines them at build time).
# For EAS cloud builds, also upload these as EAS environment variables —
# .env is gitignored and is NOT sent to the build servers.
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
EXPO_PUBLIC_FIREBASE_DATABASE_URL=https://your-project-default-rtdb.firebaseio.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your-project
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google sign-in (optional profile feature) ──────────────────────────────
# Web client ID: created automatically when you enable the Google provider in
#   Firebase Authentication (shown in the provider's settings panel).
# Android client ID: Google Cloud console → APIs & Services → Credentials →
#   Create OAuth client ID → Android, using package com.imnb57.impostor and
#   the SHA-1 from `eas credentials` (Android → production keystore).
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
